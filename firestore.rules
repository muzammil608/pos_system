rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userId() {
      return request.auth.uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(userId())).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function getAdminId() {
      return getUserRole() == 'admin' ? userId() : getUserData().adminId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(userId())) &&
        getUserRole() == 'admin';
    }

    function isActive() {
      return exists(/databases/$(database)/documents/users/$(userId())) &&
        (getUserData().isActive == null || getUserData().isActive == true);
    }

    function ownsData(ownerIdField) {
      return resource.data[ownerIdField] == getAdminId();
    }

    function creatingWithCorrectOwnerId(ownerIdField) {
      return request.resource.data[ownerIdField] == getAdminId();
    }

    // USERS
    match /users/{userDocId} {
      allow read: if isAuthenticated() && (
        userId() == userDocId ||
        isAdmin() ||
        getUserData().adminId == userId()
      );

      allow create: if isAuthenticated() && (
        userId() == userDocId || isAdmin()
      );

      allow update: if isAuthenticated() && (
        userId() == userDocId || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // PRODUCTS
    match /products/{productId} {
      allow read, update, delete: if isAuthenticated() && isActive() && ownsData('ownerId');
      allow create: if isAuthenticated() && isActive() && creatingWithCorrectOwnerId('ownerId');
    }

    // ORDERS
    match /orders/{orderId} {
      allow read, update: if isAuthenticated() && isActive() && ownsData('ownerId');
      allow create: if isAuthenticated() && isActive() && creatingWithCorrectOwnerId('ownerId');
      allow delete: if isAdmin() && ownsData('ownerId');
    }

    // COUNTERS (per-admin)
    match /counters/{counterId} {
      allow read, write: if isAuthenticated() && isActive();
    }

    // CARTS (personal)
    match /carts/{cartUserId}/{document=**} {
      allow read, write: if isAuthenticated() && userId() == cartUserId;
    }

    // DENY ALL ELSE
    match /{document=**} {
      allow read, write: if false;
    }
  }
}